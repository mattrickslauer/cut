# Cut! web — the two Alibaba Function Compute backends the frontend talks to.
# These hold the DashScope (Qwen) key server-side; the browser only calls these URLs.
# Defaults (baked into lib/config.ts) already point at the live deployed functions,
# so the app runs with no env at all. Override here to point at your own deploys / local dev.

# Director "eye" (perceive / transcribe / background) — backend/code/app.py on FC
NEXT_PUBLIC_PERCEIVE_URL=https://cut-perceive-xfdwmitvbk.ap-southeast-1.fcapp.run

# Audition reader (costar / say / warm) — audition/server/app.py on FC
NEXT_PUBLIC_AUDITION_URL=https://cut-audition-htjhmbyvbv.ap-southeast-1.fcapp.run
