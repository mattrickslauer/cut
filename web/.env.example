# Cut! web — the single Alibaba Function Compute backend the frontend talks to.
# It holds the DashScope (Qwen) key server-side; the browser only calls this URL.
# The default (baked into lib/config.ts) already points at the live deployed function,
# so the app runs with no env at all. Override here to point at your own deploy / local dev.

# Unified backend (cut-api): perceive / transcribe / background / costar / say / portrait / avatar
# Source: backend/api/app.py on FC (`cd backend/api && s deploy`). Local dev: http://localhost:8787
NEXT_PUBLIC_API_URL=https://cut-api-rjnhudrcgv.ap-southeast-1.fcapp.run
